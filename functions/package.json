{
  "name": "remind-functions",
  "version": "0.1.0",
  "private": true,
  "engines": {
    "node": "20"
  },
  "main": "lib/src/index.js",
  "scripts": {
    "build": "tsc",
    "lint": "tsc --noEmit",
    "test": "npm run build && node --test lib/test/alarms/scheduler.test.js",
    "test:rules": "npm run build && node --test lib/test/rules/firestore-rules.test.js",
    "deploy": "firebase deploy --only functions",
    "serve": "npm run build && firebase emulators:start --only functions,firestore"
  },
  "dependencies": {
    "firebase-admin": "^13.0.0",
    "firebase-functions": "^6.0.0",
    "luxon": "^3.5.0"
  },
  "devDependencies": {
    "@firebase/rules-unit-testing": "^5.0.1",
    "@types/luxon": "^3.4.2",
    "@types/node": "^22.0.0",
    "firebase": "^12.14.0",
    "typescript": "^5.7.0"
  }
}
